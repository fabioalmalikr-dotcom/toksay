# PostgreSQL connection string
# Contoh: postgres://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# Better Auth secret key (gunakan string acak panjang, minimal 32 karakter)
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Base URL aplikasi kamu (untuk Better Auth callback)
# Di Vercel, ini otomatis diisi VERCEL_PROJECT_PRODUCTION_URL
# Untuk development lokal: http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
